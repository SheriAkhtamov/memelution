APP_URL=http://localhost:5173
API_URL=http://localhost:8000
ENVIRONMENT=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://memolution:change-me@postgres:5432/memolution
REDIS_URL=redis://redis:6379/0
ENABLE_REDIS=false

JWT_SECRET=replace-with-a-random-64-byte-secret
ACCESS_TOKEN_MINUTES=43200

TELEGRAM_BOT_TOKEN=
TELEGRAM_CLIENT_ID=
TELEGRAM_CLIENT_SECRET=
TELEGRAM_REDIRECT_URI=http://localhost:8000/api/auth/telegram/callback
ENABLE_DEV_AUTH=true
DEV_SEED_ON_STARTUP=false

ADMIN_LOGIN=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

UPLOAD_DIR=/app/uploads
MAX_UPLOAD_MB=50
ALLOWED_MEDIA_TYPES=image/jpeg,image/png,image/webp,image/gif,video/mp4

S3_ENABLED=false
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY_ID=memolution
S3_SECRET_ACCESS_KEY=change-me
S3_BUCKET=memolution-media
S3_PUBLIC_URL=http://localhost:8000/media

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=180

POSTGRES_DB=memolution
POSTGRES_USER=memolution
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=memolution
MINIO_ROOT_PASSWORD=change-me
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=5173
BACKEND_PORT=8000
